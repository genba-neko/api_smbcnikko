# NAME        COMMAND  [ # DESCRIPTION ]
# - NAME: 実行するコマンド名
# - COMMAND: 実行するコマンド。@args で引数を受け取れる。
#            以下の環境変数が利用可能:
#              $PROJECT_ROOT : プロジェクトルートパス
# - DESCRIPTION: help / show-workspace-menu に表示される説明文

dev           npm run dev @args                                                   # 開発サーバー起動 (ローカル D1)
dev-remote    npm exec --no -- wrangler dev --remote @args                     # 開発サーバー起動 (リモート D1) ※wrangler v4 で非推奨
deploy        npm exec --no -- wrangler deploy @args                           # Cloudflare Workers デプロイ
test-unit     npm exec --no -- vitest run @args                                # テスト実行
type-check    npm exec --no -- tsc --noEmit @args                              # 型チェック
d1-init       TARGET=local bash tools/d1_schema.sh recreate --all              # ローカル D1 スキーマ初期化 (要 Git Bash/WSL)

# 以下はプロジェクトの package.json に対応スクリプトを定義してから有効化する
# lint          npm run lint @args   # lint チェック
# format        npm run format @args # フォーマット
